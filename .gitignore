*.tsbuildinfo

# generated data
# NOTE: data/rag-index.json IS committed on purpose — it ships the prebuilt RAG
# index so the live agent works on Vercel without a per-deploy embedding rebuild.
# Regenerate after content changes with: npm run rag:build

# vendor (third-party clones for reference)
/vendor/

# IDE
.vscode/
.idea/

# skill agents / local Claude tooling (not part of the deploy)
.agent/
.agents/
.claude/

# resume source PDFs (kept locally, not deployed) — except the one served
# from /public, which must ship so the download button works in production.
*.pdf
!public/*.pdf

# user-pasted secrets (never commit)
key.txt

.vercel
